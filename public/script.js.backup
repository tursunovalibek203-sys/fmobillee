<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Do'kon Boshqaruvi - Professional</title>
  <link rel="stylesheet" href="style.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
  <!-- Main Page -->
  <div id="mainPage" class="main-page">
    <div class="container">
      <!-- Header -->
      <div class="card header-card">
        <div class="header-content">
          <div>
            <h1>🏪 Do'kon Boshqaruvi</h1>
            <p class="subtitle" id="todayDate"></p>
          </div>
          <button class="settings-btn" onclick="openSettingsModal()">
            <span>⚙️</span>
            <span>Sozlamalar</span>
          </button>
        </div>
      </div>

      <!-- Statistics Cards -->
      <div class="stats-grid">
        <div class="stat-card blue">
          <div class="stat-icon">💰</div>
          <div class="stat-content">
            <p class="stat-label">Bugungi savdo</p>
            <p class="stat-value" id="todayTotal">0 so'm</p>
            <p class="stat-sub">To'langan: <span id="todayPaid">0 so'm</span></p>
          </div>
        </div>

        <div class="stat-card red">
          <div class="stat-icon">⚠️</div>
          <div class="stat-content">
            <p class="stat-label">Jami qarz</p>
            <p class="stat-value" id="totalDebt">0 so'm</p>
            <p class="stat-sub"><span id="debtorsCount">0</span> qarzdor</p>
          </div>
        </div>

        <div class="stat-card green">
          <div class="stat-icon">👥</div>
          <div class="stat-content">
            <p class="stat-label">Jami mijozlar</p>
            <p class="stat-value" id="totalCustomers">0</p>
            <p class="stat-sub">Faol: <span id="activeCustomers">0</span></p>
          </div>
        </div>

        <div class="stat-card purple">
          <div class="stat-icon">📊</div>
          <div class="stat-content">
            <p class="stat-label">Oylik savdo</p>
            <p class="stat-value" id="monthlyTotal">0 so'm</p>
            <p class="stat-sub">Bu oy</p>
          </div>
        </div>
      </div>

      <!-- Excel & Quick Actions -->
      <div class="actions-row">
        <div class="export-section">
          <h2>📊 Ma'lumotlar</h2>
          <div class="export-buttons">
            <button class="export-btn excel" onclick="exportToExcel()">
              <span>📥</span>
              Excel yuklab olish
            </button>
            <button class="export-btn import" onclick="document.getElementById('excelImport').click()">
              <span>📤</span>
              Excel yuklash
            </button>
            <input type="file" id="excelImport" class="file-input" accept=".xlsx,.xls" onchange="importFromExcel(event)">
          </div>
        </div>

        <div class="quick-actions">
          <h2>⚡ Tez harakatlar</h2>
          <div class="quick-btns">
            <button class="quick-btn" onclick="openAddModal()">
              <span>👤</span>
              Yangi mijoz
            </button>
            <button class="quick-btn" onclick="sendAllReminders()">
              <span>✈️</span>
              Barcha eslatma
            </button>
          </div>
        </div>
      </div>

      <!-- Main Layout -->
      <div class="main-layout">
        <!-- Left Panel - Today's Sales -->
        <div class="left-panel">
          <div class="sales-list">
            <div class="section-header">
              <h2>📋 Bugungi savdolar</h2>
              <span class="badge" id="todaySalesCount">0</span>
            </div>
            <div id="todaySalesList" class="sales-items">
              <p class="empty">Bugun savdo yo'q</p>
            </div>
          </div>
        </div>

        <!-- Right Panel - Customers -->
        <div class="right-panel">
          <div class="customers-section">
            <div class="section-header">
              <h2>👥 Mijozlar</h2>
              <div class="filter-tabs">
                <button class="filter-tab active" onclick="filterCustomers('all')">Barchasi</button>
                <button class="filter-tab" onclick="filterCustomers('debt')">Qarzdorlar</button>
                <button class="filter-tab" onclick="filterCustomers('blocked')">Bloklangan</button>
              </div>
            </div>
            
            <input type="text" class="search-input" placeholder="🔍 Mijoz qidirish..." id="searchInput" oninput="renderCustomers()">
            
            <div class="customers-grid" id="customersGrid"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Customer Detail Page (Daftar) -->
  <div id="daftarPage" class="daftar-page">
    <div class="container">
      <div class="card">
        <div class="daftar-header">
          <div class="daftar-title">
            <button class="back-btn" onclick="goBack()">
              <span>←</span>
            </button>
            <div>
              <h1>📒 <span id="customerNameTitle"></span></h1>
              <p class="subtitle" id="daftarDate"></p>
            </div>
          </div>
          <div class="header-actions">
            <button class="telegram-btn-large" onclick="sendReminderFromDaftar()" title="Telegram eslatma">
              <span>✈️</span>
            </button>
            <button class="delete-customer-btn" onclick="deleteCustomer()" title="Mijozni o'chirish">
              <span>🗑️</span>
            </button>
          </div>
        </div>
      </div>

      <!-- Debt Card -->
      <div id="debtCard" class="debt-card no-debt">
        <div class="debt-main">
          <div>
            <p class="label" id="debtLabel">✅ Balans</p>
            <p class="amount" id="debtAmount">0 so'm</p>
          </div>
          <div class="debt-status" id="debtStatus"></div>
        </div>
        <div class="info" id="debtInfo">
          <span>Jami: <span id="customerTotal">0 so'm</span></span>
          <span>To'langan: <span id="customerPaid">0 so'm</span></span>
        </div>
      </div>

      <!-- Payment Form -->
      <div class="payment-card">
        <h2>💵 To'lov qabul qilish</h2>
        <div class="payment-row">
          <input type="number" id="paymentAmount" placeholder="To'lov miqdori (so'm)">
          <button class="payment-btn" onclick="addPayment()">
            <span>💳</span>
            To'lov qabul qilish
          </button>
        </div>
      </div>

      <!-- Sale Form -->
      <div class="form-card">
        <h2 id="formTitle">➕ Yangi savdo</h2>
        <input type="text" id="productInput" placeholder="Mahsulot nomi">
        <div class="row">
          <input type="number" id="priceInput" placeholder="Narxi (so'm)">
          <input type="number" id="paidInput" placeholder="Berilgan pul (so'm)">
        </div>
        <button class="submit-btn" id="submitBtn" onclick="addSale()">
          <span>➕</span>
          Savdo qo'shish
        </button>
      </div>

      <!-- Records -->
      <div class="records-card">
        <h2>📋 Tarix (<span id="recordsCount">0</span>)</h2>
        <div id="recordsList"><p class="empty">Hali yozuv yo'q</p></div>
      </div>
    </div>
  </div>

  <!-- Settings Modal -->
  <div id="settingsModal" class="modal">
    <div class="modal-content large">
      <div class="modal-header">
        <h2>⚙️ Tizim sozlamalari</h2>
        <button class="modal-close" onclick="closeSettingsModal()">×</button>
      </div>
      
      <div class="settings-section">
        <h3>📅 Eslatma sozlamalari</h3>
        <div class="setting-item">
          <label>Necha kundan keyin eslatma yuborish:</label>
          <div class="input-group">
            <input type="number" id="reminderDays" value="7" min="1" max="30">
            <span class="setting-hint">kun</span>
          </div>
        </div>
        
        <div class="setting-item">
          <label>Eslatma yuborish vaqti:</label>
          <div class="input-group">
            <input type="time" id="reminderTime" value="09:00">
            <span class="setting-hint">soat</span>
          </div>
        </div>
      </div>

      <div class="settings-section">
        <h3>🚫 Bloklash sozlamalari</h3>
        <div class="setting-item">
          <label>Necha kundan keyin bloklash:</label>
          <div class="input-group">
            <input type="number" id="blockDays" value="10" min="1" max="90">
            <span class="setting-hint">kun</span>
          </div>
        </div>
      </div>

      <div class="settings-section">
        <h3>✉️ Qo'shimcha eslatmalar</h3>
        <div class="setting-item checkbox">
          <input type="checkbox" id="reminder3days" checked>
          <label for="reminder3days">3-kun eslatma yuborish</label>
        </div>
        <div class="setting-item checkbox">
          <input type="checkbox" id="reminder5days" checked>
          <label for="reminder5days">5-kun eslatma yuborish</label>
        </div>
        <div class="setting-item checkbox">
          <input type="checkbox" id="reminder7days" checked>
          <label for="reminder7days">7-kun eslatma yuborish</label>
        </div>
      </div>

      <div class="modal-buttons">
        <button class="cancel-btn" onclick="closeSettingsModal()">Bekor qilish</button>
        <button class="confirm-btn" onclick="saveSettings()">
          <span>✓</span>
          Saqlash
        </button>
      </div>
    </div>
  </div>

  <!-- Add Customer Modal -->
  <div id="addModal" class="modal">
    <div class="modal-content">
      <div class="modal-header">
        <h2>👤 Yangi mijoz</h2>
        <button class="modal-close" onclick="closeAddModal()">×</button>
      </div>
      <input type="text" id="newCustomerInput" placeholder="Mijoz ismi *">
      <input type="tel" id="newCustomerPhone" placeholder="Telefon: +998901234567">
      <input type="text" id="newCustomerChatId" placeholder="Telegram Chat ID">
      <p class="hint-text">
        💡 Chat ID olish: Botga /start yuboring
      </p>
      <div class="modal-buttons">
        <button class="cancel-btn" onclick="closeAddModal()">Bekor qilish</button>
        <button class="confirm-btn" onclick="addCustomer()">
          <span>✓</span>
          Qo'shish
        </button>
      </div>
    </div>
  </div>

  <!-- Reminder Modal -->
  <div id="reminderModal" class="modal">
    <div class="modal-content">
      <div class="modal-header">
        <h2>✈️ Telegram eslatma</h2>
        <button class="modal-close" onclick="closeReminderModal()">×</button>
      </div>
      <p class="modal-info">
        <strong id="reminderCustomerName"></strong> ga qarz to'lash eslatmasi yuboriladi.
      </p>
      <div class="reminder-preview">
        <p class="preview-label">Qarz miqdori:</p>
        <p class="preview-amount" id="reminderDebtAmount"></p>
      </div>
      <textarea id="reminderMessage" rows="10" placeholder="Xabar matni..."></textarea>
      <div class="modal-buttons">
        <button class="cancel-btn" onclick="closeReminderModal()">Bekor qilish</button>
        <button class="confirm-btn" onclick="sendReminder()">
          <span>✈️</span>
          Yuborish
        </button>
      </div>
    </div>
  </div>

  <!-- Scripts -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
  <script src="script.js"></script>
</body>
</html>