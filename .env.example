# ==================== ENVIRONMENT VARIABLES ====================

# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Configuration
# Atlas (SRV): mongodb+srv://user:pass@cluster.mongodb.net/dokon_db?retryWrites=true&w=majority
# querySrv xatosi bo'lsa - Atlas dan Standard Connection String oling va quyiga qo'ying:
# MONGODB_URI_STANDARD=mongodb://user:pass@cluster0-shard-00-00.xxx.mongodb.net:27017,cluster0-shard-00-01.xxx.mongodb.net:27017,cluster0-shard-00-02.xxx.mongodb.net:27017/dokon_db?ssl=true&replicaSet=atlas-xxx-shard-0&authSource=admin
# Lokal: mongodb://localhost:27017/dokon
MONGODB_URI=mongodb://localhost:27017/dokon

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-secure-password

# Telegram Bot
BOT_TOKEN=your-telegram-bot-token-here

# Security (IMPORTANT: Change these in production!)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
SESSION_SECRET=your-super-secret-session-key-minimum-32-characters
ENCRYPTION_KEY=your-64-character-hex-encryption-key-here

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPTION=true

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Monitoring
HEALTH_CHECK_ENABLED=true
ALERT_EMAIL=admin@example.com

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log
